{
  "$schema": "https://yome.work/schema/yome-skill.json",
  "slug": "@yome/ppt",
  "name": "PowerPoint",
  "description": "PowerPoint 演示文稿编辑命令（文件/幻灯片/形状/图片/表格/备注/图表，共 27 个命令）",
  "domain": "ppt",
  "version": "1.2.0",
  "official": true,
  "homepage": "https://yome.work/skills/@yome/ppt",
  "repo": "https://github.com/Whopus/yome-skill-ppt",
  "yome_min_version": "1.0.0",
  "platforms": ["macos", "ios", "sandbox"],
  "delivery": {
    "macos": {
      "backend": "ota",
      "package": "backends/macos",
      "manifest": "manifest.json",
      "implements_signature": ">=1.0.0 <2.0.0"
    },
    "ios": {
      "backend": "bundled",
      "min_app_version": "1.0.0",
      "implements_signature": ">=1.0.0 <2.0.0"
    },
    "sandbox": {
      "backend": "ota",
      "package": "backends/sandbox",
      "entry": "src/index.ts",
      "implements_signature": ">=1.0.0 <2.0.0"
    }
  },
  "ota_overlay": {
    "signature_version": "1.0.0",
    "viewer_version": "1.0.0",
    "data_version": "1.0.0"
  },
  "capabilities": ["fs:read", "fs:write", "applescript", "subprocess:python3"],
  "system_capabilities": ["fs:read", "fs:write", "applescript", "subprocess:python3"],
  "permissions_summary": {
    "zh": "读写 .pptx 文件，调用 macOS PowerPoint；图表命令需要系统 python3 + python-pptx (pip3 install python-pptx)",
    "en": "Read/write .pptx files, control macOS PowerPoint; chart commands require system python3 + python-pptx (pip3 install python-pptx)"
  },
  "tags": ["productivity", "office", "presentation"],
  "license": "Apache-2.0",
  "author": {
    "name": "Yome Official",
    "github": "Whopus"
  },
  "commands": [
    { "action": "open",            "desc": "打开已有 .pptx 文件" },
    { "action": "new",             "desc": "新建空白演示文稿" },
    { "action": "save",            "desc": "保存当前演示文稿" },
    { "action": "close",           "desc": "关闭当前文件" },
    { "action": "files",           "desc": "列出已打开的文件" },
    { "action": "slides",          "desc": "列出当前演示文稿的所有幻灯片" },
    { "action": "slide.add",       "desc": "新增一张幻灯片" },
    { "action": "slide.delete",    "desc": "删除指定幻灯片" },
    { "action": "slide.move",      "desc": "调整幻灯片顺序" },
    { "action": "slide.duplicate", "desc": "复制幻灯片" },
    { "action": "get",             "desc": "读取某张幻灯片的全部形状" },
    { "action": "read",            "desc": "读取某个形状的文字内容" },
    { "action": "set",             "desc": "设置某个形状的文字" },
    { "action": "addtext",         "desc": "在幻灯片上新增文本框" },
    { "action": "title",           "desc": "设置幻灯片标题" },
    { "action": "fmt",             "desc": "调整字体 / 颜色 / 对齐 / 加粗等格式" },
    { "action": "export",          "desc": "导出为 PDF / 图片" },
    { "action": "shape.delete",    "desc": "删除形状" },
    { "action": "shape.move",      "desc": "移动形状" },
    { "action": "shape.resize",    "desc": "调整形状尺寸" },
    { "action": "shape.add",       "desc": "插入自选图形（矩形/椭圆/箭头/星形等）" },
    { "action": "picture.add",     "desc": "在幻灯片插入图片" },
    { "action": "notes.set",       "desc": "设置演讲者备注" },
    { "action": "notes.get",       "desc": "读取演讲者备注" },
    { "action": "table.add",       "desc": "插入表格" },
    { "action": "table.set",       "desc": "设置表格单元格文字" },
    { "action": "charts",          "desc": "列出该幻灯片上所有图表" },
    { "action": "chart.add",       "desc": "添加图表（CSV 数据源，python-pptx 实现）" },
    { "action": "chart.update",    "desc": "替换已有图表的数据（python-pptx 实现）" },
    { "action": "chart.delete",    "desc": "删除图表（python-pptx 实现）" }
  ]
}
